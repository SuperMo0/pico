{%- liquid
  assign social_size = size | default: 18
  assign has_social = false
  if settings.social_instagram_url != blank or settings.social_facebook_url != blank or settings.social_tiktok_url != blank or settings.social_twitter_url != blank or settings.social_youtube_url != blank
    assign has_social = true
  endif
-%}
{%- if has_social -%}
<ul class="social-icons{% if tone %} social-icons--{{ tone }}{% endif %}">
  {%- if settings.social_instagram_url != blank -%}
    <li>
      <a href="{{ settings.social_instagram_url }}" class="social-icons__link" aria-label="{{ 'accessibility.follow_instagram' | t }}" target="_blank" rel="noopener noreferrer">
        {%- render 'icon', icon: 'instagram', size: social_size -%}
      </a>
    </li>
  {%- endif -%}
  {%- if settings.social_tiktok_url != blank -%}
    <li>
      <a href="{{ settings.social_tiktok_url }}" class="social-icons__link" aria-label="{{ 'accessibility.follow_tiktok' | t }}" target="_blank" rel="noopener noreferrer">
        {%- render 'icon', icon: 'tiktok', size: social_size -%}
      </a>
    </li>
  {%- endif -%}
  {%- if settings.social_facebook_url != blank -%}
    <li>
      <a href="{{ settings.social_facebook_url }}" class="social-icons__link" aria-label="{{ 'accessibility.follow_facebook' | t }}" target="_blank" rel="noopener noreferrer">
        {%- render 'icon', icon: 'facebook', size: social_size -%}
      </a>
    </li>
  {%- endif -%}
  {%- if settings.social_twitter_url != blank -%}
    <li>
      <a href="{{ settings.social_twitter_url }}" class="social-icons__link" aria-label="{{ 'accessibility.follow_twitter' | t }}" target="_blank" rel="noopener noreferrer">
        {%- render 'icon', icon: 'twitter-x', size: social_size -%}
      </a>
    </li>
  {%- endif -%}
  {%- if settings.social_youtube_url != blank -%}
    <li>
      <a href="{{ settings.social_youtube_url }}" class="social-icons__link" aria-label="{{ 'accessibility.follow_youtube' | t }}" target="_blank" rel="noopener noreferrer">
        {%- render 'icon', icon: 'youtube', size: social_size -%}
      </a>
    </li>
  {%- endif -%}
</ul>
{%- endif -%}

{% stylesheet %}
.social-icons {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-1);
}

.social-icons__link {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 40px;
  height: 40px;
  border-radius: var(--radius-sm);
  color: inherit;
  text-decoration: none;
  transition: opacity var(--dur-fast) var(--ease-soft);
}

.social-icons__link:hover {
  opacity: 0.7;
}

.social-icons__link:focus-visible {
  outline: 2px solid var(--border-focus);
  outline-offset: 2px;
  border-radius: var(--radius-sm);
}

@media (hover: none) {
  .social-icons__link {
    width: 44px;
    height: 44px;
  }
}

.social-icons--light .social-icons__link {
  color: var(--cream-200);
}

.social-icons--light .social-icons__link:hover {
  color: var(--cream-50);
  opacity: 1;
}

.social-icons--dark .social-icons__link {
  color: var(--ink-700);
}

.social-icons--dark .social-icons__link:hover {
  color: var(--ink-900);
  opacity: 1;
}
{% endstylesheet %}
