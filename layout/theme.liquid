<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="rtl">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Google Fonts — Tajawal (display) + IBM Plex Sans Arabic (body) %}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Tajawal:wght@400;500;700;800&family=IBM+Plex+Sans+Arabic:wght@400;500;700&display=swap">

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Beeko design tokens + RTL global stylesheet %}
    {{ 'theme.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    <script src="{{ 'slider-component.js' | asset_url }}" defer></script>
    <script src="{{ 'product-form.js' | asset_url }}" defer></script>
    <script src="{{ 'popup-modal.js' | asset_url }}" defer></script>
    <script src="{{ 'product-recommendations.js' | asset_url }}" defer></script>
    <script>
      window.__wishlistCustomerId = {{ customer.id | json }};
      window.__wishlistServerItems = {{ customer.metafields.wishlist.items.value | json }};
      window.__wishlistI18n = {
        add:   {{ 'products.product.add_to_wishlist' | t | json }},
        remove: {{ 'products.product.remove_from_wishlist' | t | json }},
        added: {{ 'products.product.added_to_wishlist' | t | json }}
      };
    </script>
    <script src="{{ 'wishlist.js' | asset_url }}" defer></script>

    {{ content_for_header }}
  </head>

  <body>
    {% sections 'header-group' %}

    {{ content_for_layout }}
    <popup-modal
      id="quick-view-modal"
      data-close-label="{{ 'accessibility.close_modal' | t }}"
      data-error-text="{{ 'products.product.quick_view_error' | t }}"></popup-modal>

    {% sections 'footer-group' %}

    <div id="wishlist-toast" class="wishlist-toast" role="status" hidden></div>
  </body>
</html>
