{%- liquid
  assign eb_img  = section.settings.image
  assign eb_pos  = section.settings.image_position | default: 'right'
  if eb_img != blank
    assign img_alt   = eb_img.alt | default: section.settings.heading
    assign img_style = 'object-fit: cover; object-position: ' | append: eb_img.presentation.focal_point
  endif
-%}

<section class="editorial-band" aria-labelledby="eb-heading-{{ section.id }}">
  <div class="editorial-band__outer">
    <div class="editorial-band__band{%- if eb_pos == 'left' %} editorial-band__band--img-left{%- endif %}">

      <div class="editorial-band__text">
        {%- if section.settings.eyebrow != blank -%}
          <div class="beeko-eyebrow editorial-band__eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        <h2 id="eb-heading-{{ section.id }}" class="editorial-band__heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.body != blank -%}
          <div class="editorial-band__body">{{ section.settings.body }}</div>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url }}" class="btn btn--accent editorial-band__cta">{{ section.settings.cta_label }}</a>
        {%- endif -%}
      </div>

      <div class="editorial-band__media">
        {%- if eb_img != blank -%}
          {{ eb_img | image_url: width: 800 | image_tag: alt: img_alt, widths: '400,600,800', sizes: '(min-width: 768px) 50vw, 100vw', loading: 'lazy', style: img_style }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'editorial-band__placeholder' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% stylesheet %}
.editorial-band {
  padding-block: var(--space-10);
}

.editorial-band__outer {
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-pad);
}

.editorial-band__band {
  display: grid;
  grid-template-columns: 1fr;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: var(--sage-100);
}

.editorial-band__text {
  padding: var(--space-8);
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.editorial-band__eyebrow {
  margin-bottom: 12px;
}

.editorial-band__heading {
  font-size: var(--fs-h2);
  margin-bottom: var(--space-4);
}

.editorial-band__body {
  font-size: var(--fs-body-lg);
  color: var(--ink-800);
  max-width: 40ch;
  margin-bottom: var(--space-5);
}

.editorial-band__body p {
  margin: 0;
}

.editorial-band__media {
  aspect-ratio: 1 / 1;
  background: var(--cream-100);
  overflow: hidden;
}

.editorial-band__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.editorial-band__placeholder {
  width: 100%;
  height: 100%;
}

@media (min-width: 768px) {
  .editorial-band__band {
    grid-template-columns: 1fr 1fr;
  }

  .editorial-band__heading {
    font-size: var(--fs-h1);
  }

  .editorial-band__band--img-left .editorial-band__text {
    order: 2;
  }

  .editorial-band__band--img-left .editorial-band__media {
    order: 1;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.editorial_band.name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.editorial_band.settings.eyebrow",
      "default": "لماذا القطن؟"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.editorial_band.settings.heading",
      "default": "خامة تتنفّس، تبقى ناعمة"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "t:sections.editorial_band.settings.body",
      "default": "<p>نختار قطنًا طبيعيًا لطيفًا على البشرة الحسّاسة، ويحتفظ بنعومته بعد كل غسلة.</p>"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "t:sections.editorial_band.settings.cta_label",
      "default": "اعرفي أكثر"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "t:sections.editorial_band.settings.cta_url"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.editorial_band.settings.image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.editorial_band.settings.image_position",
      "options": [
        { "value": "right", "label": "t:sections.editorial_band.settings.image_position_right" },
        { "value": "left",  "label": "t:sections.editorial_band.settings.image_position_left"  }
      ],
      "default": "right"
    }
  ],
  "presets": [
    {
      "name": "t:sections.editorial_band.presets.name",
      "settings": {
        "eyebrow": "لماذا القطن؟",
        "heading": "خامة تتنفّس، تبقى ناعمة",
        "body": "<p>نختار قطنًا طبيعيًا لطيفًا على البشرة الحسّاسة، ويحتفظ بنعومته بعد كل غسلة.</p>",
        "cta_label": "اعرفي أكثر",
        "image_position": "right"
      }
    }
  ]
}
{% endschema %}
