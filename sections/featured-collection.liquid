{%- liquid
  assign fc_col   = section.settings.collection
  assign fc_count = section.settings.product_count | default: 4 | plus: 0
  assign view_all_text = section.settings.view_all_label
  if view_all_text == blank
    assign view_all_text = 'sections.featured_collection.view_all' | t
  endif
-%}
<section class="featured-collection" aria-labelledby="fc-heading-{{ section.id }}">
  <div class="featured-collection__inner">
    <div class="featured-collection__header">
      <h2 id="fc-heading-{{ section.id }}" class="featured-collection__heading">
        {{ section.settings.heading }}
      </h2>
      {%- if fc_col != blank -%}
        <a href="{{ fc_col.url }}" class="featured-collection__view-all">
          {{- view_all_text }} ←
        </a>
      {%- endif -%}
    </div>

    <div class="featured-collection__grid">
      {%- if fc_col != blank -%}
        {%- for product in fc_col.products limit: fc_count -%}
          <div>{% render 'product-card', product: product %}</div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="featured-collection__placeholder">
            {{ 'product-' | append: i | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
.featured-collection {
  padding-block: var(--space-10);
}

.featured-collection__inner {
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-pad);
}

.featured-collection__header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: var(--space-6);
  gap: var(--space-4);
}

.featured-collection__heading {
  font-size: var(--fs-h2);
  margin: 0;
}

.featured-collection__view-all {
  font-family: var(--font-body);
  font-size: var(--fs-sm);
  font-weight: var(--fw-semibold);
  color: var(--text-body);
  text-decoration: none;
  white-space: nowrap;
  flex-shrink: 0;
}

.featured-collection__view-all:hover {
  color: var(--text-accent);
}

.featured-collection__view-all:focus-visible {
  outline: 2px solid var(--border-focus);
  outline-offset: 2px;
}

.featured-collection__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: var(--grid-gutter);
}

@media (min-width: 768px) {
  .featured-collection__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.featured-collection__placeholder {
  aspect-ratio: 4 / 5;
  border-radius: var(--radius-lg);
  overflow: hidden;
  background: var(--cream-100);
}

.featured-collection__placeholder .placeholder-svg {
  width: 100%;
  height: 100%;
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.featured_collection.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.featured_collection.settings.heading",
      "default": "الأكثر مبيعًا"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "t:sections.featured_collection.settings.collection"
    },
    {
      "type": "select",
      "id": "product_count",
      "label": "t:sections.featured_collection.settings.product_count",
      "options": [
        { "value": "4",  "label": "4"  },
        { "value": "8",  "label": "8"  },
        { "value": "12", "label": "12" }
      ],
      "default": "4"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": "t:sections.featured_collection.settings.view_all_label"
    }
  ],
  "presets": [
    {
      "name": "t:sections.featured_collection.presets.name",
      "settings": {
        "heading": "الأكثر مبيعًا",
        "product_count": "4"
      }
    }
  ]
}
{% endschema %}
