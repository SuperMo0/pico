{%- liquid
  assign coll = product.collections.first
  assign count = section.settings.product_count | default: 8 | plus: 0
  assign heading = section.settings.heading
  if heading == blank
    assign heading = 'sections.same_collection.heading' | t
  endif

  assign carousel_id = 'sc-' | append: section.id

  assign sibling_count = 0
  if coll
    assign sibling_count = coll.products_count | minus: 1
  endif
-%}
{%- if sibling_count > 0 -%}
  <section class="same-collection" aria-labelledby="{{ carousel_id }}-heading">
    <div class="same-collection__inner">
      {% render 'product-carousel',
        products: coll.products,
        heading: heading,
        id: carousel_id,
        limit: count,
        exclude_id: product.id
      %}
    </div>
  </section>
{%- endif -%}

{% stylesheet %}
.same-collection { display: block; }
.same-collection__inner {
  padding-block: var(--space-5);
  padding-inline: var(--container-pad);
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.same_collection.name",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.same_collection.settings.heading"
    },
    {
      "type": "select",
      "id": "product_count",
      "label": "t:sections.same_collection.settings.product_count",
      "options": [
        { "value": "4", "label": "4" },
        { "value": "8", "label": "8" },
        { "value": "10", "label": "10" }
      ],
      "default": "8"
    }
  ],
  "presets": [
    { "name": "t:sections.same_collection.presets.name" }
  ],
  "enabled_on": { "templates": ["product"] }
}
{% endschema %}
