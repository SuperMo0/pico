{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign form_id         = 'product-form-' | append: section.id
  assign first_accordion = true
-%}

<section class="product" aria-labelledby="product-title-{{ section.id }}">
  <div class="product__inner">

    {%- if section.settings.show_breadcrumb -%}
      <nav class="product__breadcrumb" aria-label="breadcrumb">
        <a href="{{ routes.root_url }}" class="product__breadcrumb-link">{{ 'sections.product.breadcrumb_home' | t }}</a>
        <span class="product__breadcrumb-sep" aria-hidden="true">/</span>
        <span aria-current="page">{{ product.title }}</span>
      </nav>
    {%- endif -%}

    <div class="product__grid">

      {%- comment -%}——— Gallery column ———{%- endcomment -%}
      {% render 'product-gallery', product: product, section_id: section.id %}

      {%- comment -%}——— Info column (block-driven) ———{%- endcomment -%}
      <product-form
        class="product__info"
        data-section-id="{{ section.id }}">

        <script type="application/json" id="product-json-{{ section.id }}">{{ product | json }}</script>

        {%- form 'product', product, id: form_id -%}
          <input type="hidden" name="id" value="{{ current_variant.id }}" id="variant-id-{{ section.id }}">

          {%- for block in section.blocks -%}
            {%- case block.type -%}

              {%- when 'title' -%}
                {% render 'product-title', product: product, section_id: section.id, shopify_attributes: block.shopify_attributes %}

              {%- when 'price' -%}
                {% render 'product-price', product: product, section_id: section.id, shopify_attributes: block.shopify_attributes %}

              {%- when 'description' -%}
                {%- if product.description != blank -%}
                  <div class="product__description" {{ block.shopify_attributes }}>{{ product.description }}</div>
                {%- endif -%}

              {%- when 'variant_picker' -%}
                {% render 'product-variant-picker',
                  product: product,
                  section_id: section.id,
                  show_size_guide: block.settings.show_size_guide,
                  size_guide_page: block.settings.size_guide_page,
                  shopify_attributes: block.shopify_attributes
                %}

              {%- when 'buy_buttons' -%}
                {% render 'product-buy-buttons', product: product, section_id: section.id, shopify_attributes: block.shopify_attributes %}

              {%- when 'trust' -%}
                <div class="product__trust" aria-hidden="true" {{ block.shopify_attributes }}>
                  <span class="product-trust-chip">
                    {%- render 'icon', icon: 'leaf', size: 15 -%}
                    {{ 'sections.product.trust_cotton' | t }}
                  </span>
                  <span class="product-trust-chip">
                    {%- render 'icon', icon: 'feather', size: 15 -%}
                    {{ 'sections.product.trust_gentle' | t }}
                  </span>
                  <span class="product-trust-chip">
                    {%- render 'icon', icon: 'truck', size: 15 -%}
                    {{ 'sections.product.trust_shipping' | t }}
                  </span>
                </div>

              {%- when 'accordion_panel' -%}
                {%- if block.settings.title != blank -%}
                  <details class="product-accordion__item{% if first_accordion %} product-accordion__item--first{% endif %}"
                           {% if first_accordion %}open{% endif %}
                           {{ block.shopify_attributes }}>
                    <summary class="product-accordion__trigger">
                      <span class="product-accordion__trigger-text">{{ block.settings.title }}</span>
                      <span class="product-accordion__icon product-accordion__icon--plus" aria-hidden="true">
                        {%- render 'icon', icon: 'plus', size: 18 -%}
                      </span>
                      <span class="product-accordion__icon product-accordion__icon--minus" aria-hidden="true">
                        {%- render 'icon', icon: 'minus', size: 18 -%}
                      </span>
                    </summary>
                    {%- if block.settings.content != blank -%}
                      <div class="product-accordion__body">{{ block.settings.content }}</div>
                    {%- endif -%}
                  </details>
                  {%- assign first_accordion = false -%}
                {%- endif -%}

            {%- endcase -%}
          {%- endfor -%}

        {%- endform -%}
      </product-form>

    </div>{%- comment -%} .product__grid {%- endcomment -%}

  </div>
</section>

{% stylesheet %}

/* Layout, breadcrumb, description, trust, accordion, and desktop grid are
   product-page-only. Shared component styles (gallery, title, price, variant
   options, qty/ATC) live in assets/theme.css so the quick-view modal can reuse
   them — the Sections API does not ship this section's stylesheet bundle. */

/* ── Layout ─────────────────────────────── */
.product {
  padding-block: var(--space-6) var(--space-8);
}

.product__inner {
  padding-inline: var(--container-pad);
}

.product__breadcrumb {
  display: flex;
  align-items: center;
  gap: 6px;
  font-family: var(--font-body);
  font-size: var(--fs-xs);
  color: var(--text-muted);
  margin-bottom: var(--space-5);
}

.product__breadcrumb-link {
  color: var(--text-muted);
  text-decoration: none;
}
.product__breadcrumb-link:hover { color: var(--text-accent); }
.product__breadcrumb-link:focus-visible { outline: 2px solid var(--border-focus); outline-offset: 2px; }

/* Mobile: stacked */
.product__grid {
  display: flex;
  flex-direction: column;
  gap: var(--space-7);
}

.product__description {
  color: var(--text-body);
  font-family: var(--font-body);
  font-size: var(--fs-body-lg);
  max-width: 46ch;
  line-height: 1.7;
  margin-bottom: var(--space-6);
}

/* ── Trust chips ─────────────────────────── */
.product__trust {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-bottom: var(--space-6);
}

.product-trust-chip {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 6px 12px;
  border-radius: var(--radius-pill);
  border: 1px solid var(--border-hairline);
  background: var(--surface-raised);
  font-family: var(--font-body);
  font-size: var(--fs-xs);
  font-weight: var(--fw-medium);
  color: var(--ink-800);
}

/* ── Accordion ───────────────────────────── */
.product-accordion__item {
  border-bottom: 1px solid var(--border-hairline);
}

.product-accordion__item--first {
  border-top: 1px solid var(--border-hairline);
}

.product-accordion__trigger {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 16px 0;
  cursor: pointer;
  font-family: var(--font-display);
  font-weight: var(--fw-bold);
  font-size: var(--fs-h4);
  color: var(--ink-900);
  list-style: none;
}

.product-accordion__trigger::-webkit-details-marker { display: none; }

.product-accordion__trigger:focus-visible { outline: 2px solid var(--border-focus); outline-offset: 2px; }

.product-accordion__icon--minus { display: none; }

details[open] .product-accordion__icon--plus  { display: none; }
details[open] .product-accordion__icon--minus { display: inline-flex; }

.product-accordion__body {
  color: var(--text-body);
  font-family: var(--font-body);
  font-size: var(--fs-body);
  line-height: 1.8;
  padding-bottom: 16px;
}

/* ── Desktop ─────────────────────────────── */
@media (min-width: 768px) {
  .product__grid {
    display: grid;
    grid-template-columns: 1.1fr 1fr;
    gap: var(--space-8);
    align-items: start;
  }

  product-gallery {
    display: grid;
    grid-template-columns: 72px 1fr;
    gap: var(--space-3);
    align-items: start;
  }

  /* Thumbs: column 1, vertical */
  .product-gallery__thumbs {
    order: 0;
    grid-column: 1;
    flex-direction: column;
    overflow-x: visible;
    overflow-y: auto;
    padding-block-end: 0;
    gap: 10px;
  }

  .product-gallery__thumb {
    flex: none;
    width: 100%;
  }

  /* Slider: column 2 */
  .product-gallery__slider-wrap {
    order: 0;
    grid-column: 2;
  }

  product-form {
    position: sticky;
    top: 96px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.product.name",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "t:sections.product.settings.show_breadcrumb",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "title",
      "name": "t:sections.product.blocks.title.name",
      "limit": 1
    },
    {
      "type": "price",
      "name": "t:sections.product.blocks.price.name",
      "limit": 1
    },
    {
      "type": "description",
      "name": "t:sections.product.blocks.description.name",
      "limit": 1
    },
    {
      "type": "variant_picker",
      "name": "t:sections.product.blocks.variant_picker.name",
      "limit": 1,
      "settings": [
        {
          "type": "checkbox",
          "id": "show_size_guide",
          "label": "t:sections.product.blocks.variant_picker.settings.show_size_guide",
          "default": true
        },
        {
          "type": "page",
          "id": "size_guide_page",
          "label": "t:sections.product.blocks.variant_picker.settings.size_guide_page"
        }
      ]
    },
    {
      "type": "buy_buttons",
      "name": "t:sections.product.blocks.buy_buttons.name",
      "limit": 1
    },
    {
      "type": "trust",
      "name": "t:sections.product.blocks.trust.name",
      "limit": 1
    },
    {
      "type": "accordion_panel",
      "name": "t:sections.product.blocks.accordion_panel.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.product.blocks.accordion_panel.settings.title"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "t:sections.product.blocks.accordion_panel.settings.content"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:sections.product.name",
      "blocks": [
        { "type": "title" },
        { "type": "price" },
        { "type": "description" },
        { "type": "variant_picker", "settings": { "show_size_guide": true } },
        {
          "type": "accordion_panel",
          "settings": {
            "title": "دليل المقاسات",
            "content": "<p>راجع جدول المقاسات للعثور على المقاس المناسب لطفلك.</p>"
          }
        },
        { "type": "buy_buttons" },
        { "type": "trust" },
        {
          "type": "accordion_panel",
          "settings": {
            "title": "تفاصيل المنتج",
            "content": "<p>تفاصيل عن المنتج.</p>"
          }
        },
        {
          "type": "accordion_panel",
          "settings": {
            "title": "الخامة والعناية",
            "content": "<p>قطن ١٠٠٪. يُغسل في الغسالة على ٣٠°. لا يُستخدم مبيّض.</p>"
          }
        },
        {
          "type": "accordion_panel",
          "settings": {
            "title": "الشحن والإرجاع",
            "content": "<p>شحن مجاني للطلبات فوق ٢٠٠ ر.س. إرجاع سهل خلال ١٤ يومًا.</p>"
          }
        }
      ]
    }
  ],
  "disabled_on": {
    "groups": ["header", "footer"]
  }
}
{% endschema %}
