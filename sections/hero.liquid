{%- liquid
  assign hero_img = section.settings.image
  assign text_variant = section.settings.text_color | default: 'light'
  assign veil = section.settings.overlay_opacity | default: 45
  assign veil_alpha = veil | divided_by: 100.0

  if hero_img != blank
    assign img_alt = hero_img.alt | default: section.settings.heading
    assign img_style = 'object-position: ' | append: hero_img.presentation.focal_point
  endif
-%}

<section
  class="hero full-width hero--text-{{ text_variant }}"
  aria-labelledby="hero-heading-{{ section.id }}"
  style="--hero-veil-alpha: {{ veil_alpha }};"
>
  <div class="hero__media">
    {%- if hero_img != blank -%}
      {{ hero_img | image_url: width: 2400 | image_tag: alt: img_alt, class: 'hero__img', widths: '600,900,1200,1600,2000,2400', sizes: '100vw', loading: 'eager', fetchpriority: 'high', style: img_style }}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'hero__img hero__img--placeholder' }}
    {%- endif -%}
    <div class="hero__veil" aria-hidden="true"></div>
  </div>

  <div class="hero__content">
    {%- if section.settings.eyebrow_text != blank -%}
      <p class="beeko-eyebrow hero__eyebrow">{{ section.settings.eyebrow_text }}</p>
    {%- endif -%}

    <h1 id="hero-heading-{{ section.id }}" class="hero__heading">
      {{ section.settings.heading }}
    </h1>

    {%- if section.settings.subheading != blank -%}
      <div class="hero__sub">{{ section.settings.subheading }}</div>
    {%- endif -%}

    {%- if section.settings.primary_cta_label != blank or section.settings.secondary_cta_label != blank -%}
      <div class="hero__ctas">
        {%- if section.settings.primary_cta_label != blank -%}
          <a href="{{ section.settings.primary_cta_url | default: routes.all_products_collection_url }}" class="btn btn--lg hero__cta hero__cta--primary">
            {{ section.settings.primary_cta_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_cta_label != blank -%}
          <a href="{{ section.settings.secondary_cta_url | default: routes.all_products_collection_url }}" class="btn btn--lg hero__cta hero__cta--secondary">
            {{ section.settings.secondary_cta_label }}
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.hero {
  position: relative;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  min-height: 80vh;
  min-height: 80svh;
  padding-block: 0;
  overflow: hidden;
  isolation: isolate;
  padding-bottom: var(--space-5);
}

.hero--text-light { --hero-text: var(--cream-50); --hero-veil-rgb: 43, 39, 33; }
.hero--text-dark  { --hero-text: var(--ink-900);  --hero-veil-rgb: 252, 250, 246; }

.hero__media {
  position: absolute;
  inset: 0;
  z-index: -1;
  background: var(--cream-100);
}

.hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

/* Mobile: veil rises from the bottom so low-anchored text stays legible. */
.hero__veil {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(var(--hero-veil-rgb), var(--hero-veil-alpha)) 0%,
    rgba(var(--hero-veil-rgb), calc(var(--hero-veil-alpha) * 0.42)) 38%,
    rgba(var(--hero-veil-rgb), 0) 62%
  );
}

.hero__content {
  position: relative;
  width: 100%;
  padding-inline: var(--container-pad);
  padding-block-end: var(--space-8);
  text-align: start;
  color: var(--hero-text);
}

.hero__eyebrow {
  color: var(--hero-text);
  opacity: 0.92;
  margin-bottom: var(--space-3);
}

.hero__heading {
  font-size: clamp(var(--fs-h2), 6vw, 2.75rem);
  line-height: var(--lh-tight);
  color: var(--hero-text);
  margin: 0 0 var(--space-4);
  max-width: 18ch;
}

.hero__sub {
  font-size: var(--fs-body-lg);
  color: var(--hero-text);
  opacity: 0.92;
  max-width: 42ch;
  margin-bottom: var(--space-5);
}

.hero__sub p { margin: 0; }

.hero__ctas {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
}

/* Hero CTAs flip color with the chosen text variant so they pop on the photo. */
.hero--text-light .hero__cta--primary {
  background: var(--cream-50);
  color: var(--ink-900);
  border-color: var(--cream-50);
}
.hero--text-light .hero__cta--primary:hover {
  background: #fff;
  border-color: #fff;
}
.hero--text-light .hero__cta--secondary {
  background: transparent;
  color: var(--cream-50);
  border-color: rgba(252, 250, 246, 0.85);
}
.hero--text-light .hero__cta--secondary:hover {
  background: rgba(252, 250, 246, 0.14);
}

.hero--text-dark .hero__cta--primary {
  background: var(--ink-900);
  color: var(--cream-50);
  border-color: var(--ink-900);
}
.hero--text-dark .hero__cta--primary:hover {
  background: var(--ink-800);
  border-color: var(--ink-800);
}
.hero--text-dark .hero__cta--secondary {
  background: transparent;
  color: var(--ink-900);
  border-color: var(--ink-900);
}
.hero--text-dark .hero__cta--secondary:hover {
  background: rgba(43, 39, 33, 0.06);
}

.hero__cta {
  min-height: 44px;
}

/* Desktop: text centers over a calmer, flat wash. */
@media (min-width: 768px) {
  .hero {
    justify-content: center;
    min-height: clamp(440px, 72vh, 760px);
  }

  .hero__veil {
    background: rgba(var(--hero-veil-rgb), calc(var(--hero-veil-alpha) * 0.62));
  }

  .hero__content {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-block-end: 0;
    text-align: center;
  }

  .hero__heading {
    font-size: var(--fs-display);
    line-height: var(--lh-heading);
    max-width: 22ch;
    margin-inline: auto;
  }

  .hero__sub {
    margin-inline: auto;
  }

  .hero__ctas {
    justify-content: center;
  }
}

@media (prefers-reduced-motion: reduce) {
  .hero__cta { transition: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero.name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "t:sections.hero.settings.eyebrow_text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero.settings.heading",
      "default": "قطن ناعم لكل لحظات اللعب"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.hero.settings.subheading"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.hero.settings.image"
    },
    {
      "type": "select",
      "id": "text_color",
      "label": "t:sections.hero.settings.text_color",
      "options": [
        { "value": "light", "label": "t:sections.hero.settings.text_color_light" },
        { "value": "dark", "label": "t:sections.hero.settings.text_color_dark" }
      ],
      "default": "light"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "t:sections.hero.settings.overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "t:sections.hero.settings.primary_cta_label",
      "default": "تسوّقي المجموعة"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "t:sections.hero.settings.primary_cta_url"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "t:sections.hero.settings.secondary_cta_label"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "t:sections.hero.settings.secondary_cta_url"
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero.presets.name",
      "settings": {
        "eyebrow_text": "مجموعة المنزل"
      }
    }
  ]
}
{% endschema %}
