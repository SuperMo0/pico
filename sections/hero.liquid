{%- liquid
  assign img_pos  = section.settings.image_position | default: 'right'
  assign hero_img = section.settings.image
  assign img_alt  = hero_img.alt | default: section.settings.heading
  assign img_style = 'object-fit: cover; object-position: ' | append: hero_img.presentation.focal_point
-%}

<section class="hero" aria-labelledby="hero-heading-{{ section.id }}">
  <div class="hero__inner{% if img_pos == 'left' %} hero__inner--img-left{% endif %}">

    <div class="hero__text">
      {%- if section.settings.eyebrow_text != blank -%}
        <div class="beeko-eyebrow hero__eyebrow">{{ section.settings.eyebrow_text }}</div>
      {%- endif -%}

      <h1 id="hero-heading-{{ section.id }}" class="hero__heading">
        {{ section.settings.heading }}
      </h1>

      {%- if section.settings.subheading != blank -%}
        <div class="hero__sub">{{ section.settings.subheading }}</div>
      {%- endif -%}

      <div class="hero__ctas">
        {%- if section.settings.primary_cta_label != blank -%}
          <a href="{{ section.settings.primary_cta_url }}" class="btn btn--primary btn--lg">
            {{ section.settings.primary_cta_label }}
          </a>
        {%- endif -%}
        {%- if section.settings.secondary_cta_label != blank -%}
          <a href="{{ section.settings.secondary_cta_url }}" class="btn btn--outline btn--lg">
            {{ section.settings.secondary_cta_label }}
          </a>
        {%- endif -%}
      </div>
    </div>

    <div class="hero__media">
      {%- if hero_img != blank -%}
        {{ hero_img | image_url: width: 900 | image_tag: alt: img_alt, widths: '400,600,900', sizes: '(min-width: 768px) 50vw, 100vw', loading: 'eager', fetchpriority: 'high', style: img_style }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'hero__placeholder' }}
      {%- endif -%}
    </div>

  </div>
</section>

{% stylesheet %}
.hero {
  max-width: var(--container-max);
  margin-inline: auto;
  padding-inline: var(--container-pad);
  padding-block: var(--space-8);
}

.hero__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-6);
}

.hero__text {
  order: 1;
}

.hero__media {
  order: 2;
  border-radius: var(--radius-xl);
  overflow: hidden;
  background: var(--cream-100);
  aspect-ratio: 4 / 5;
  max-height: 60vw;
}

.hero__media img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.hero__placeholder {
  width: 100%;
  height: 100%;
}

.hero__eyebrow {
  margin-bottom: var(--space-4);
}

.hero__heading {
  font-size: var(--fs-h1);
  line-height: var(--lh-tight);
  margin-bottom: var(--space-4);
}

.hero__sub {
  font-size: var(--fs-body-lg);
  color: var(--text-body);
  max-width: 46ch;
  margin-bottom: var(--space-6);
}

.hero__sub p { margin: 0; }

.hero__ctas {
  display: flex;
  gap: var(--space-3);
  flex-wrap: wrap;
}

@media (min-width: 768px) {
  .hero {
    padding-block: var(--space-10);
  }

  .hero__inner {
    grid-template-columns: 1fr 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  .hero__media {
    max-height: none;
  }

  .hero__heading {
    font-size: var(--fs-display);
    line-height: 1.15;
  }

  .hero__inner--img-left .hero__text { order: 2; }
  .hero__inner--img-left .hero__media { order: 1; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.hero.name",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow_text",
      "label": "t:sections.hero.settings.eyebrow_text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.hero.settings.heading",
      "default": "قطن ناعم… ليوم كامل من اللعب والراحة"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "t:sections.hero.settings.subheading",
      "default": "<p>ملابس منزلية مريحة بألوان هادئة، مصنوعة من قطن لطيف على بشرة طفلك.</p>"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.hero.settings.image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "t:sections.hero.settings.image_position",
      "options": [
        { "value": "right", "label": "t:sections.hero.settings.image_position_right" },
        { "value": "left",  "label": "t:sections.hero.settings.image_position_left" }
      ],
      "default": "right"
    },
    {
      "type": "text",
      "id": "primary_cta_label",
      "label": "t:sections.hero.settings.primary_cta_label",
      "default": "تسوّقي المجموعة"
    },
    {
      "type": "url",
      "id": "primary_cta_url",
      "label": "t:sections.hero.settings.primary_cta_url"
    },
    {
      "type": "text",
      "id": "secondary_cta_label",
      "label": "t:sections.hero.settings.secondary_cta_label",
      "default": "حديثو الولادة"
    },
    {
      "type": "url",
      "id": "secondary_cta_url",
      "label": "t:sections.hero.settings.secondary_cta_url"
    }
  ],
  "presets": [
    {
      "name": "t:sections.hero.presets.name",
      "settings": {
        "eyebrow_text": "مجموعة المنزل"
      }
    }
  ]
}
{% endschema %}
