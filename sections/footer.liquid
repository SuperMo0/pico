{%- liquid
  assign copyright = section.settings.copyright_text
  if copyright == blank
    assign copyright = 'sections.footer.copyright' | t
  endif
  assign trust = section.settings.trust_tagline
  if trust == blank
    assign trust = 'sections.footer.trust_tagline' | t
  endif
  assign logo_img = section.settings.logo
  unless logo_img
    assign logo_img = shop.brand.logo
  endunless 
  assign logo_w = section.settings.logo_width | default: 120
  assign logo_w2x = logo_w | times: 2
  assign logo_widths = logo_w | append: ',' | append: logo_w2x
  assign logo_sizes = logo_w | append: 'px'
-%}
<footer class="footer full-width" role="contentinfo" aria-labelledby="footer-heading-{{ section.id }}"
  style="--footer-logo-w: {{ logo_w }}px">
  <span id="footer-heading-{{ section.id }}" class="visually-hidden">{{ shop.name }}</span>
  <div class="footer__inner">
    <div class="footer__grid">

      <div class="footer__brand">
        {%- if logo_img != blank -%}
          {{ logo_img | image_url: width: logo_w | image_tag:
            alt: shop.name,
            class: 'footer__logo',
            widths: logo_widths,
            sizes: logo_sizes,
            loading: 'lazy'
          }}
        {%- else -%}
          <span class="footer__shop-name">{{ shop.name }}</span>
        {%- endif -%}
        {%- if section.settings.brand_description != blank -%}
          <div class="footer__brand-desc">{{ section.settings.brand_description }}</div>
        {%- endif -%}
        <div class="footer__brand-desc__social">
          تابعنا على 
        {%- render 'social-icons', tone: 'light' -%}
        </div>
      </div>

      {%- for block in section.blocks -%}
        <div class="footer__col" {{ block.shopify_attributes }}>
          {%- if block.settings.heading != blank -%}
            <div class="footer__col-heading">{{ block.settings.heading }}</div>
          {%- endif -%}
          {%- if block.settings.menu != blank -%}
            <ul class="footer__links">
              {%- for link in block.settings.menu.links -%}
                <li><a href="{{ link.url }}" class="footer__link">{{ link.title }}</a></li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      {%- endfor -%}

    </div>

    <div class="footer__bottom">
      <span class="footer__copyright">{{ copyright }}</span>
      <span class="footer__trust">{{ trust }}</span>
    </div>
  </div>
</footer>

{% stylesheet %}
.footer {
  background: var(--ink-900);
  color: var(--cream-200);
  margin-top: var(--space-12);
}

.footer__inner {
  margin-inline: auto;
  padding: var(--space-10) var(--container-pad) var(--space-7);
}

.footer__grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  grid-template-rows: auto auto;
  gap: var(--space-5);
  padding-inline: var(--space-2);
}

.footer__brand{
  grid-column: 1/-1;
}

@media (min-width: 601px) {
  .footer__grid {
    grid-template-columns: 1fr 1fr;
  }
}

 @media (min-width: 768px) {
   .footer{
      padding-inline: var(--space-10);
   }
}

@media (min-width: 900px) {
  .footer__grid {
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    grid-template-rows: 1fr;
  }
  .footer__brand{
  grid-column: 1/2;
}
}

.footer__logo {
  width: var(--footer-logo-w, 120px);
  height: auto;
  display: block;
  /* filter: brightness(0) invert(1); */
  opacity: 0.9;
}

.footer__shop-name {
  display: block;
  font-family: var(--font-display);
  font-size: var(--fs-h3);
  font-weight: var(--fw-bold);
  color: var(--cream-50);
  margin-bottom: var(--space-3);
}

.footer__brand-desc {
  font-family: var(--font-body);
  font-size: var(--fs-sm);
  line-height: 1.8;
  color: var(--cream-200);
  margin-top: var(--space-4);
  max-width: 34ch;
}

.footer__brand-desc p {
  margin: 0;
}

.footer__brand-desc__social{
    margin-top: var(--space-5);
    display: flex;
    gap: var(--space-1);
    align-items: center;
}

.footer__brand .social-icons {
  margin-inline-start: calc(var(--space-1) * -1);
}

.footer__col-heading {
  font-family: var(--font-display);
  font-weight: var(--fw-bold);
  font-size: var(--fs-h4);
  color: var(--cream-50);
  margin-bottom: var(--space-4);
}

.footer__links {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.footer__link {
  font-family: var(--font-body);
  font-size: var(--fs-sm);
  color: var(--cream-200);
  text-decoration: none;
  transition: color var(--dur-fast) var(--ease-soft);
}

.footer__link:hover {
  color: var(--cream-50);
}

.footer__link:focus-visible {
  outline: 2px solid var(--border-focus);
  outline-offset: 2px;
  border-radius: 2px;
}

.footer__bottom {
  margin-top: var(--space-8);
  padding-top: var(--space-5);
  border-top: 1px solid rgba(252, 250, 246, 0.14);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-5);
  flex-wrap: wrap;
}

.footer__copyright,
.footer__trust {
  font-family: var(--font-body);
  font-size: var(--fs-xs);
  color: var(--cream-200);
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "richtext",
      "id": "brand_description",
      "label": "t:sections.footer.settings.brand_description"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "t:sections.footer.settings.copyright_text"
    },
    {
      "type": "text",
      "id": "trust_tagline",
      "label": "t:sections.footer.settings.trust_tagline"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "t:sections.footer.settings.logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "t:sections.footer.settings.logo_width",
      "min": 60,
      "max": 300,
      "step": 10,
      "default": 120,
      "unit": "px"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "link_list",
      "name": "t:sections.footer.blocks.link_list.name",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:sections.footer.blocks.link_list.settings.heading"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "t:sections.footer.blocks.link_list.settings.menu"
        }
      ]
    }
  ]
}
{% endschema %}
