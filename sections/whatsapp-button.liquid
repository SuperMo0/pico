{%- liquid
  assign wa_number = section.settings.phone | strip | remove: '+' | remove: ' ' | remove: '-' | remove: '(' | remove: ')'

  if wa_number != blank
    assign wa_url = 'https://wa.me/' | append: wa_number
    if section.settings.message != blank
      assign wa_text = section.settings.message | url_encode
      assign wa_url = wa_url | append: '?text=' | append: wa_text
    endif
  endif

  assign position_class = section.settings.position | default: 'whatsapp-fab--br'
-%}

{%- if wa_number != blank -%}
  <a
    class="whatsapp-fab {{ position_class }}"
    href="{{ wa_url }}"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="{{ 'sections.whatsapp_button.aria_label' | t }}"
  >
    <svg class="whatsapp-fab__glyph" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="30" height="30" fill="currentColor" aria-hidden="true" focusable="false">
      <path d="M12.04 2C6.58 2 2.13 6.45 2.13 11.91c0 1.75.46 3.45 1.32 4.95L2 22l5.25-1.38c1.45.79 3.08 1.21 4.79 1.21h.01c5.46 0 9.91-4.45 9.91-9.91 0-2.65-1.03-5.14-2.9-7.01A9.82 9.82 0 0 0 12.04 2m0 1.67c2.2 0 4.27.86 5.82 2.42a8.18 8.18 0 0 1 2.41 5.82c0 4.54-3.7 8.23-8.24 8.23-1.48 0-2.93-.4-4.19-1.15l-.3-.18-3.12.82.83-3.04-.2-.31a8.18 8.18 0 0 1-1.26-4.38c.01-4.54 3.7-8.25 8.25-8.25M8.53 7.33c-.16 0-.43.06-.66.31-.22.25-.87.85-.87 2.07 0 1.22.89 2.39 1 2.56.14.17 1.76 2.67 4.25 3.73.59.27 1.05.42 1.41.53.59.19 1.13.16 1.56.1.48-.07 1.46-.6 1.67-1.18.21-.58.21-1.07.15-1.18-.07-.1-.23-.16-.48-.27-.25-.14-1.47-.74-1.69-.82-.23-.08-.37-.12-.56.12-.16.25-.64.81-.78.97-.15.17-.29.19-.53.07-.26-.13-1.06-.39-2-1.23-.74-.66-1.23-1.48-1.38-1.72-.12-.24-.01-.39.11-.5.11-.11.27-.29.37-.44.13-.14.17-.25.25-.41.08-.17.04-.31-.02-.43-.06-.11-.56-1.35-.77-1.84-.2-.48-.4-.42-.56-.43h-.47z"/>
    </svg>
  </a>
{%- endif -%}

{% stylesheet %}
.whatsapp-fab {
  position: fixed;
  z-index: 60;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56px;
  height: 56px;
  border-radius: var(--radius-pill);
  /* WhatsApp brand green — recognizable, trusted contact mark (kept off the calm palette on purpose). */
  background: #25d366;
  color: var(--cream-50);
  box-shadow: var(--shadow-md);
  transition: transform var(--dur-fast) var(--ease-soft), box-shadow var(--dur-fast) var(--ease-soft), background var(--dur-fast) var(--ease-soft);
}

.whatsapp-fab:hover {
  background: #1da851;
  box-shadow: var(--shadow-lg);
  transform: translateY(-2px);
}

.whatsapp-fab:focus-visible {
  outline: 2px solid var(--border-focus);
  outline-offset: 3px;
}

.whatsapp-fab__glyph {
  display: block;
}

/* Position variants — fixed to the viewport corners, clear of safe-area insets. */
.whatsapp-fab--br {
  inset-block-end: calc(var(--space-5) + env(safe-area-inset-bottom, 0px));
  inset-inline-end: var(--space-5);
}
.whatsapp-fab--bl {
  inset-block-end: calc(var(--space-5) + env(safe-area-inset-bottom, 0px));
  inset-inline-start: var(--space-5);
}
.whatsapp-fab--tr {
  inset-block-start: var(--space-5);
  inset-inline-end: var(--space-5);
}
.whatsapp-fab--tl {
  inset-block-start: var(--space-5);
  inset-inline-start: var(--space-5);
}

@media (prefers-reduced-motion: reduce) {
  .whatsapp-fab { transition: none; }
  .whatsapp-fab:hover { transform: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.whatsapp_button.name",
  "settings": [
    {
      "type": "text",
      "id": "phone",
      "label": "t:sections.whatsapp_button.settings.phone",
      "info": "t:sections.whatsapp_button.settings.phone_info"
    },
    {
      "type": "text",
      "id": "message",
      "label": "t:sections.whatsapp_button.settings.message",
      "info": "t:sections.whatsapp_button.settings.message_info"
    },
    {
      "type": "select",
      "id": "position",
      "label": "t:sections.whatsapp_button.settings.position",
      "options": [
        { "value": "whatsapp-fab--br", "label": "t:sections.whatsapp_button.settings.position_bottom_right" },
        { "value": "whatsapp-fab--bl", "label": "t:sections.whatsapp_button.settings.position_bottom_left" },
        { "value": "whatsapp-fab--tr", "label": "t:sections.whatsapp_button.settings.position_top_right" },
        { "value": "whatsapp-fab--tl", "label": "t:sections.whatsapp_button.settings.position_top_left" }
      ],
      "default": "whatsapp-fab--br"
    }
  ],
  "presets": [
    { "name": "t:sections.whatsapp_button.name" }
  ]
}
{% endschema %}
