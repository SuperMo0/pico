{%- liquid
  assign threshold       = section.settings.free_shipping_threshold | default: 200
  assign threshold_cents = threshold | times: 100
  assign remain_cents    = threshold_cents | minus: cart.total_price | at_least: 0
  assign remain_money    = remain_cents | money
  assign pct             = cart.total_price | times: 1.0 | divided_by: threshold | at_most: 100 | round
-%}

<cart-drawer
  id="cart-drawer"
  class="cart-drawer"
  role="dialog"
  aria-modal="true"
  aria-labelledby="cart-drawer-heading"
  data-section-id="{{ section.id }}"
  hidden
>
  <div class="cart-drawer__scrim" data-action="close"></div>

  <aside class="cart-drawer__panel">

    <div id="cart-drawer-contents">

      <div class="cart-drawer__header">
        <h2 id="cart-drawer-heading" class="cart-drawer__title">
          {{ 'sections.cart_drawer.title' | t }}
          {%- if cart.item_count > 0 -%}
            <span class="cart-drawer__count" aria-live="polite">({{ cart.item_count }})</span>
          {%- else -%}
            <span class="cart-drawer__count" aria-live="polite"></span>
          {%- endif -%}
        </h2>
        <button type="button" class="cart-drawer__close" aria-label="{{ 'accessibility.close_menu' | t }}" data-action="close">
          {% render 'icon', icon: 'x', size: 20 %}
        </button>
      </div>

      {%- if cart.item_count > 0 -%}

        <div class="cart-drawer__shipping-bar">
          <p class="cart-drawer__shipping-text">
            {%- if remain_cents > 0 -%}
              {{ 'sections.cart_drawer.free_shipping_progress' | t: amount: remain_money }}
            {%- else -%}
              {{ 'sections.cart_drawer.free_shipping_achieved' | t }}
            {%- endif -%}
          </p>
          <div class="cart-drawer__shipping-track"
               role="progressbar"
               aria-valuemin="0"
               aria-valuemax="100"
               aria-valuenow="{{ pct }}">
            <div class="cart-drawer__shipping-fill" style="width: {{ pct }}%"></div>
          </div>
        </div>

        <div class="cart-drawer__body">
          <ul class="cart-drawer__items" aria-label="{{ 'sections.cart_drawer.title' | t }}">
            {%- for item in cart.items -%}
              {%- liquid
                assign img_focal = item.image.presentation.focal_point | default: 'center center'
                assign img_style = 'object-fit:cover;object-position:' | append: img_focal
              -%}
              <li class="cart-drawer__item">
                <div class="cart-drawer__item-img">
                  {%- if item.image -%}
                    {{ item.image | image_url: width: 160 | image_tag: alt: item.product.title, loading: 'lazy', width: 78, height: 96, style: img_style }}
                  {%- endif -%}
                </div>
                <div class="cart-drawer__item-info">
                  <div class="cart-drawer__item-top">
                    <span class="cart-drawer__item-title">{{ item.product.title }}</span>
                    <button type="button"
                            class="cart-drawer__remove"
                            data-item-key="{{ item.key }}"
                            data-action="remove"
                            aria-label="{{ 'sections.cart_drawer.remove_item' | t }}">
                      {%- render 'icon', icon: 'trash-2', size: 16 -%}
                    </button>
                  </div>
                  {%- unless item.variant.title == 'Default Title' -%}
                    <span class="cart-drawer__item-variant">{{ item.variant.title }}</span>
                  {%- endunless -%}
                  <div class="cart-drawer__item-bottom">
                    <div class="cart-drawer__qty" data-item-key="{{ item.key }}">
                      <button type="button" class="cart-drawer__qty-btn" data-delta="-1" aria-label="{{ 'sections.product.quantity_decrement' | t }}">
                        {%- render 'icon', icon: 'minus', size: 14 -%}
                      </button>
                      <span class="cart-drawer__qty-val">{{ item.quantity }}</span>
                      <button type="button" class="cart-drawer__qty-btn" data-delta="1" aria-label="{{ 'sections.product.quantity_increment' | t }}">
                        {%- render 'icon', icon: 'plus', size: 14 -%}
                      </button>
                    </div>
                    <span class="cart-drawer__item-price">{{ item.final_line_price | money }}</span>
                  </div>
                </div>
              </li>
            {%- endfor -%}
          </ul>
        </div>

        <div class="cart-drawer__footer">
          <div class="cart-drawer__subtotal-row">
            <span class="cart-drawer__subtotal-label">{{ 'sections.cart_drawer.subtotal' | t }}</span>
            <span class="cart-drawer__subtotal-price">{{ cart.total_price | money }}</span>
          </div>
          <form action="{{ routes.cart_url }}" method="post">
            <button type="submit" name="checkout" class="btn btn--primary btn--lg cart-drawer__checkout">
              {{ 'sections.cart_drawer.checkout' | t }}
            </button>
          </form>
          <p class="cart-drawer__tax-note">{{ 'sections.cart_drawer.tax_note' | t }}</p>
        </div>

      {%- else -%}

        <div class="cart-drawer__body">
          <div class="cart-drawer__empty">
            <span class="cart-drawer__empty-icon" aria-hidden="true">
              {% render 'icon', icon: 'shopping-bag', size: 40 %}
            </span>
            <p class="cart-drawer__empty-text">{{ 'sections.cart_drawer.empty_heading' | t }}</p>
            <button type="button" class="btn btn--outline" data-action="close">
              {{ 'sections.cart_drawer.continue_shopping' | t }}
            </button>
          </div>
        </div>

      {%- endif -%}

    </div>{%- comment -%}#cart-drawer-contents{%- endcomment -%}

  </aside>
</cart-drawer>

{% stylesheet %}
cart-drawer {
  display: block;
}

.cart-drawer__scrim {
  position: fixed;
  inset: 0;
  background: rgba(43, 39, 33, 0.32);
  z-index: 90;
  opacity: 0;
  pointer-events: none;
  transition: opacity var(--dur-base) var(--ease-soft);
}

.cart-drawer--open .cart-drawer__scrim {
  opacity: 1;
  pointer-events: auto;
}

.cart-drawer__panel {
  position: fixed;
  top: 0;
  bottom: 0;
  inset-inline-start: 0;
  width: 420px;
  max-width: 92vw;
  z-index: 100;
  background: var(--surface-page);
  display: flex;
  flex-direction: column;
  box-shadow: var(--shadow-lg);
  transform: translateX(100%);
  transition: transform var(--dur-base) var(--ease-soft);
}

.cart-drawer--open .cart-drawer__panel {
  transform: translateX(0);
}

#cart-drawer-contents {
  display: contents;
}

.cart-drawer__header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-5);
  border-bottom: 1px solid var(--border-hairline);
  flex-shrink: 0;
}

.cart-drawer__title {
  font-family: var(--font-display);
  font-weight: var(--fw-bold);
  font-size: var(--fs-h3);
  color: var(--text-strong);
  margin: 0;
  display: flex;
  align-items: baseline;
  gap: 6px;
}

.cart-drawer__count {
  font-family: var(--font-body);
  font-size: var(--fs-body);
  font-weight: var(--fw-regular);
  color: var(--text-muted);
}

.cart-drawer__close {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-700);
  border-radius: var(--radius-sm);
  transition: color var(--dur-fast) var(--ease-soft), background var(--dur-fast) var(--ease-soft);
  flex-shrink: 0;
}

.cart-drawer__close:hover {
  color: var(--ink-900);
  background: var(--surface-sunken);
}

.cart-drawer__close:focus-visible {
  outline: 2px solid var(--border-focus);
  outline-offset: 2px;
}

.cart-drawer__shipping-bar {
  padding: var(--space-4) var(--space-5);
  background: var(--surface-sunken);
  border-bottom: 1px solid var(--border-hairline);
  flex-shrink: 0;
}

.cart-drawer__shipping-text {
  font-family: var(--font-body);
  font-size: var(--fs-xs);
  color: var(--ink-700);
  margin: 0 0 8px;
}

.cart-drawer__shipping-track {
  height: 6px;
  border-radius: var(--radius-pill);
  background: var(--sand-200);
  overflow: hidden;
}

.cart-drawer__shipping-fill {
  height: 100%;
  background: var(--sage-600);
  border-radius: var(--radius-pill);
  transition: width var(--dur-base) var(--ease-soft);
}

.cart-drawer__body {
  flex: 1;
  overflow-y: auto;
  overscroll-behavior: contain;
  display: flex;
  flex-direction: column;
}

.cart-drawer__items {
  list-style: none;
  margin: 0;
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.cart-drawer__item {
  display: flex;
  gap: var(--space-3);
}

.cart-drawer__item-img {
  width: 78px;
  height: 96px;
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--cream-100);
  flex-shrink: 0;
}

.cart-drawer__item-img img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.cart-drawer__item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.cart-drawer__item-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-2);
}

.cart-drawer__item-title {
  font-family: var(--font-body);
  font-size: var(--fs-sm);
  font-weight: var(--fw-semibold);
  color: var(--ink-900);
  overflow-wrap: break-word;
}

.cart-drawer__remove {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-500);
  padding: 4px;
  border-radius: var(--radius-xs);
  flex-shrink: 0;
  transition: color var(--dur-fast) var(--ease-soft);
}

.cart-drawer__remove:hover { color: var(--sale-600); }

.cart-drawer__remove:focus-visible {
  outline: 2px solid var(--border-focus);
  outline-offset: 2px;
}

.cart-drawer__item-variant {
  font-family: var(--font-body);
  font-size: var(--fs-xs);
  color: var(--text-muted);
  margin-top: 2px;
}

.cart-drawer__item-bottom {
  margin-top: auto;
  padding-top: var(--space-3);
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: var(--space-2);
}

.cart-drawer__qty {
  display: inline-flex;
  align-items: center;
  border: 1px solid var(--border-hairline);
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.cart-drawer__qty-btn {
  width: 32px;
  height: 32px;
  background: none;
  border: none;
  cursor: pointer;
  color: var(--ink-700);
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: background var(--dur-fast) var(--ease-soft);
}

.cart-drawer__qty-btn:hover { background: var(--surface-sunken); }

.cart-drawer__qty-btn:focus-visible {
  outline: 2px solid var(--border-focus);
  outline-offset: -2px;
}

.cart-drawer__qty-val {
  min-width: 28px;
  text-align: center;
  font-family: var(--font-body);
  font-size: var(--fs-sm);
  color: var(--ink-900);
}

.cart-drawer__item-price {
  font-family: var(--font-body);
  font-size: var(--fs-sm);
  font-weight: var(--fw-semibold);
  color: var(--text-strong);
  white-space: nowrap;
}

.cart-drawer__empty {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--space-4);
  padding: var(--space-6);
  text-align: center;
}

.cart-drawer__empty-icon {
  color: var(--ink-300);
  display: inline-flex;
}

.cart-drawer__empty-text {
  margin: 0;
  font-family: var(--font-body);
  font-size: var(--fs-body);
  color: var(--text-muted);
}

.cart-drawer__footer {
  padding: var(--space-5);
  border-top: 1px solid var(--border-hairline);
  flex-shrink: 0;
}

.cart-drawer__subtotal-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: var(--space-4);
}

.cart-drawer__subtotal-label {
  font-family: var(--font-display);
  font-weight: var(--fw-bold);
  font-size: var(--fs-h4);
  color: var(--text-strong);
}

.cart-drawer__subtotal-price {
  font-family: var(--font-body);
  font-size: var(--fs-body);
  font-weight: var(--fw-semibold);
  color: var(--text-strong);
}

.cart-drawer__checkout {
  width: 100%;
  justify-content: center;
  display: flex;
}

.cart-drawer__footer form {
  display: block;
  margin-bottom: 0;
}

.cart-drawer__tax-note {
  text-align: center;
  font-family: var(--font-body);
  font-size: var(--fs-xs);
  color: var(--text-muted);
  margin: 12px 0 0;
}

#cart-drawer-contents[aria-busy="true"] {
  opacity: 0.5;
  pointer-events: none;
  transition: opacity var(--dur-fast) var(--ease-soft);
}

html.scroll-lock {
  overflow: hidden;
}
{% endstylesheet %}

{% javascript %}
class CartDrawer extends HTMLElement {
  #controller = null;

  connectedCallback() {
    this._sectionId = this.dataset.sectionId;

    this.addEventListener('click', (e) => {
      if (e.target.closest('[data-action="close"]')) {
        this.close();
        return;
      }
      const removeBtn = e.target.closest('[data-action="remove"][data-item-key]');
      if (removeBtn) {
        this.#changeQty(removeBtn.dataset.itemKey, 0);
        return;
      }
      const qtyBtn = e.target.closest('.cart-drawer__qty-btn');
      if (qtyBtn) {
        const row = qtyBtn.closest('.cart-drawer__qty');
        const current = parseInt(row.querySelector('.cart-drawer__qty-val').textContent, 10);
        const next = Math.max(0, current + parseInt(qtyBtn.dataset.delta, 10));
        this.#changeQty(row.dataset.itemKey, next);
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && this.classList.contains('cart-drawer--open')) this.close();
    });

    document.addEventListener('theme:cart:updated', (e) => {
      if (!e.detail?.sectionHtml) return;
      this.#applySection(e.detail.sectionHtml);
      this.open();
    });

    document.addEventListener('theme:cart:open', () => {
      fetch(`${window.location.pathname}?sections=${this._sectionId}`)
        .then((r) => r.json())
        .then((data) => {
          this.#applySection(data[this._sectionId]);
          this.open();
        })
        .catch((err) => console.error('[cart-drawer]', err));
    });
  }

  open() {
    this.hidden = false;
    requestAnimationFrame(() => this.classList.add('cart-drawer--open'));
    document.documentElement.classList.add('scroll-lock');
    requestAnimationFrame(() => this.querySelector('.cart-drawer__close')?.focus());
  }

  close() {
    this.classList.remove('cart-drawer--open');
    document.documentElement.classList.remove('scroll-lock');
    setTimeout(() => { this.hidden = true; }, 220);
  }

  #applySection(html) {
    if (!html) return;
    const doc = new DOMParser().parseFromString(html, 'text/html');
    const incoming = doc.querySelector('#cart-drawer-contents');
    const current = this.querySelector('#cart-drawer-contents');
    if (incoming && current) current.replaceWith(incoming);
  }

  async #changeQty(key, qty) {
    this.#controller?.abort();
    this.#controller = new AbortController();

    const contents = this.querySelector('#cart-drawer-contents');
    contents?.setAttribute('aria-busy', 'true');

    try {
      const res = await fetch('/cart/change.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: key, quantity: qty, sections: [this._sectionId] }),
        signal: this.#controller.signal,
      });
      if (!res.ok) throw new Error(`/cart/change.js ${res.status}`);
      const data = await res.json();
      this.#applySection(data.sections?.[this._sectionId]);
      document.dispatchEvent(new CustomEvent('theme:cart:updated', {
        detail: { cart: data },
      }));
    } catch (err) {
      if (err.name !== 'AbortError') {
        console.error('[cart-drawer]', err);
        this.querySelector('#cart-drawer-contents')?.removeAttribute('aria-busy');
      }
    }
  }
}

if (!customElements.get('cart-drawer')) {
  customElements.define('cart-drawer', CartDrawer);
}
{% endjavascript %}

{% schema %}
{
  "name": "t:sections.cart_drawer.name",
  "settings": [
    {
      "type": "number",
      "id": "free_shipping_threshold",
      "label": "t:sections.cart_drawer.settings.free_shipping_threshold",
      "default": 200
    }
  ]
}
{% endschema %}
