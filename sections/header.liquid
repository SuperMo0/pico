<header class="site-header">
  <h2 class="header__title">
    {{ shop.name | link_to: routes.root_url }}
  </h2>

  <div class="header__menu">
    {% for link in section.settings.menu.links %}
      {{ link.title | link_to: link.url }}
    {% endfor %}
  </div>

  <div class="header__icons">
    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a href="{{ routes.cart_url }}" aria-label="{{ 'sections.header.cart_label' | t }}">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}

      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>
  </div>
</header>

{% stylesheet %}
  .site-header {
    height: 5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-inline: var(--container-pad);
    max-width: var(--container-max);
    margin-inline: auto;
    width: 100%;
    background-color: var(--surface-page);
  }

  .site-header a {
    position: relative;
    text-decoration: none;
    color: var(--text-strong);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color var(--dur-fast) var(--ease-soft);
  }

  .site-header a:hover {
    color: var(--text-accent);
  }

  .site-header a sup {
    position: absolute;
    left: 100%;
    overflow: hidden;
    max-width: var(--page-margin);
  }

  .site-header svg {
    width: 2rem;
  }

  .header__menu,
  .header__icons {
    display: flex;
    gap: var(--space-4);
  }

  .header__title {
    font-size: var(--fs-h3);
    margin: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:sections.header.name",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "t:labels.menu"
    },
    {
      "type": "link_list",
      "id": "customer_account_menu",
      "label": "t:labels.customer_account_menu",
      "default": "customer-account-main-menu"
    }
  ]
}
{% endschema %}
